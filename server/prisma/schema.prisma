generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  name         String?
  avatarUrl    String?
  role         UserRole    @default(TEAM)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  tickets        Ticket[]
  chamados       Chamado[]
  monthlyStats   MonthlyData[]
  healthConfigs  HealthScoreConfig[]
  healthHistory  HealthScoreHistory[]
}

enum UserRole {
  MANAGER
  TEAM
}

model Ticket {
  id                String   @id @default(uuid())
  originalId        String?  // The ID from the CSV if applicable
  titulo            String
  status            String
  dataAbertura      String   // Keeping as string to match CSV format for now, or could parse to DateTime
  ultimaAtualizacao String?
  requerente        String?
  tecnico           String?
  categoria         String?
  localizacao       String?
  origem            String?

  userId            String
  user              User     @relation(fields: [userId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Chamado {
  id             String   @id @default(uuid())
  numeroChamado  String
  resumo         String
  criado         String
  fimDoPrazo     String?
  prazoAjustado  String?
  statusChamado  String
  relator        String?
  modulo         String?
  funcionalidade String?

  userId         String
  user           User     @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MonthlyData {
  id          String   @id @default(uuid())
  month       String   // Format: "YYYY-MM"
  satisfaction String? // Stored as string to match frontend "4.5"
  manuals     String?  // Stored as string to match frontend "10"
  projetos     String?  // Projetos
  treinamentos String?  // Treinamentos ministrados no mês
  peticionamento String? // Evolução de Peticionamento
  extrajudiciais String? // Novos Extrajudiciais
  documentos    String? // Documentos Emitidos
  movimentos    String? // Movimentos Taxonômicos
  aiInsights    Json?   // Insights gerados pela IA (Cache)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, month]) // Ensure one stat record per month per team
}

model CorporateData {
  id        Int      @id @default(1)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsage {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Configurações do Health Score (Versionáveis)
model HealthScoreConfig {
  id             Int      @id @default(autoincrement())
  userId         String   // Gestor/Time
  user           User     @relation(fields: [userId], references: [id])
  active         Boolean  @default(true)
  version        Int      @default(1) // Para reprocessar histórico com pesos antigos se necessário ou aplicar novos retroativamente

  // Modos e Pesos
  useSLA         Boolean  @default(false)
  weightSLA      Float    @default(0.25)
  weightTMA      Float    @default(0.20)
  weightBacklog  Float    @default(0.25)
  weightCapac    Float    @default(0.15)
  weightProd     Float    @default(0.15)
  weightSatis    Float    @default(0.0) // Futuro

  // Metas (Gatilhos de Normalização 0-100)
  targetTMAHours       Float // Meta ideal TMA (horas)
  criticalTMAHours     Float // Limite crítico TMA (horas) (score 0)
  targetBacklog        Int
  criticalBacklog      Int
  targetProdPerTech    Int   // Produtividade por técnico
  avgCapacityPerTech   Int   // Capacidade média por técnico

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, version])
}

// Armazenamento dos Resultados Calculados (Cache Permanente)
model HealthScoreHistory {
  id              String   @id @default(uuid())
  userId          String   // Gestor/Time
  user            User     @relation(fields: [userId], references: [id])
  month           String   // Ex: YYYY-MM
  configVersion   Int      // Qual versão da config gerou este score

  // Scores Normalizados (0-100)
  scoreTotal      Float
  scoreSLA        Float?   // Nulo se useSLA = false
  scoreTMA        Float
  scoreBacklog    Float
  scoreCapacidade Float
  scoreProdutiv   Float

  // Extrato Bruto Base (Para não recalcular sempre)
  rawTicketsCount Int
  rawChamadosCount Int
  rawTMAHours     Float
  rawBacklogCount Int
  rawProdTickets  Int

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, month, configVersion])
}
