generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  password      String
  name          String?
  role          UserRole             @default(TEAM)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  avatarUrl     String?
  chamados      Chamado[]
  healthConfigs HealthScoreConfig[]
  healthHistory HealthScoreHistory[]
  monthlyStats  MonthlyData[]
  tickets       Ticket[]
}

model Ticket {
  id                String   @id @default(uuid())
  originalId        String?
  titulo            String
  status            String
  dataAbertura      String
  ultimaAtualizacao String?
  requerente        String?
  tecnico           String?
  categoria         String?
  localizacao       String?
  origem            String?
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model Chamado {
  id             String   @id @default(uuid())
  numeroChamado  String
  resumo         String
  criado         String
  fimDoPrazo     String?
  prazoAjustado  String?
  statusChamado  String
  relator        String?
  modulo         String?
  funcionalidade String?
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model MonthlyData {
  id             String   @id @default(uuid())
  month          String
  satisfaction   String?
  manuals        String?
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  projetos       String?
  treinamentos   String?
  peticionamento String?
  extrajudiciais String?
  documentos     String?
  movimentos     String?
  aiInsights     Json?
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model CorporateData {
  id        Int      @id @default(1)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiUsage {
  id        Int      @id @default(autoincrement())
  date      String   @unique
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model HealthScoreConfig {
  id                 Int      @id @default(autoincrement())
  userId             String
  active             Boolean  @default(true)
  version            Int      @default(1)
  useSLA             Boolean  @default(false)
  weightSLA          Float    @default(0.25)
  weightTMA          Float    @default(0.20)
  weightBacklog      Float    @default(0.25)
  weightCapac        Float    @default(0.15)
  weightProd         Float    @default(0.15)
  weightSatis        Float    @default(0.0)
  targetTMAHours     Float
  criticalTMAHours   Float
  targetBacklog      Int
  criticalBacklog    Int
  targetProdPerTech  Int
  avgCapacityPerTech Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@unique([userId, version])
}

model HealthScoreHistory {
  id               String   @id @default(uuid())
  userId           String
  month            String
  configVersion    Int
  scoreTotal       Float
  scoreSLA         Float?
  scoreTMA         Float
  scoreBacklog     Float
  scoreCapacidade  Float
  scoreProdutiv    Float
  rawTicketsCount  Int
  rawChamadosCount Int
  rawTMAHours      Float
  rawBacklogCount  Int
  rawProdTickets   Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, configVersion])
}

enum UserRole {
  MANAGER
  TEAM
}
